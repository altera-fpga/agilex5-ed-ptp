                         "p0_rx_eop_u %0d, p0_rx_eop_l %0d\n",
                         "p0_rx_sop %0d, p0_rx_eop %0d"},
                        p0_rx_sop_u, p0_rx_sop_l, p0_rx_eop_u, p0_rx_eop_l, p0_rx_sop, p0_rx_eop),
              UVM_LOW)
  endtask

